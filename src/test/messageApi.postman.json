          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 or 201', () => {",
                  "  pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
                  "});",
                  "pm.test('Save conversationId', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.success).to.be.true;",
                  "  pm.expect(json.data._id).to.exist;",
                  "  pm.collectionVariables.set('conversationId', json.data._id);",
                  "  console.log('conversationId saved:', json.data._id);",
                  "});",
                  "pm.test('Has participants', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.data.participants).to.be.an('array').with.lengthOf(2);",
                  "});"
