            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "// Set verificationToken variable from your MongoDB or email before running",
                  "// pm.collectionVariables.set('verificationToken', 'your_token_here');"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const json = pm.response.json();",
                  "  if (json.data && json.data.token) {",
                  "    pm.collectionVariables.set('authToken', json.data.token);",
                  "    console.log('Auth token saved:', json.data.token.substring(0, 20) + '...');",
                  "  }",
                  "  pm.test('Email verified', () => pm.expect(json.success).to.be.true);",
                  "}"
                ]
