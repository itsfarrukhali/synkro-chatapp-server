        {
          "name": "Get Messages (First page)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/conversations/{{conversationId}}/messages?limit=20",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "conversations",
                "{{conversationId}}",
                "messages"
              ],
              "query": [
                {
                  "key": "limit",
                  "value": "20"
                }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Pagination shape', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.data).to.have.property('messages');",
                  "  pm.expect(json.data).to.have.property('hasMore');",
                  "  pm.expect(json.data).to.have.property('nextCursor');",
                  "  pm.expect(json.data.messages).to.be.an('array');",
                  "});",
                  "pm.test('Messages in chronological order', () => {",
                  "  const msgs = pm.response.json().data.messages;",
                  "  if (msgs.length > 1) {",
                  "    const t1 = new Date(msgs[0].createdAt).getTime();",
                  "    const t2 = new Date(msgs[1].createdAt).getTime();",
                  "    pm.expect(t1).to.be.lte(t2);",
                  "  }",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Messages (Cursor-based — older page)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/conversations/{{conversationId}}/messages?cursor=2025-01-01T00:00:00.000Z&limit=10",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "conversations",
                "{{conversationId}}",
                "messages"
              ],
              "query": [
                {
                  "key": "cursor",
                  "value": "2025-01-01T00:00:00.000Z"
                },
                {
                  "key": "limit",
                  "value": "10"
                }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Older messages returned', () => {",
                  "  const json = pm.response.json();",
                  "  json.data.messages.forEach(msg => {",
                  "    pm.expect(new Date(msg.createdAt).getTime()).to.be.lt(new Date('2025-01-01').getTime());",
                  "  });",
                  "});"
                ]
              }
            }
          ]
        },
