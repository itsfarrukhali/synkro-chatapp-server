    {
      "name": "📨 Messages",
      "item": [
        {
          "name": "Send Message (Text)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"content\": \"Hello from Postman REST!\",\n  \"type\": \"text\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/conversations/{{conversationId}}/messages",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "conversations",
                "{{conversationId}}",
                "messages"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "pm.test('Message created — save ID', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.success).to.be.true;",
                  "  pm.expect(json.data._id).to.exist;",
                  "  pm.expect(json.data.content).to.eql('Hello from Postman REST!');",
                  "  pm.expect(json.data).to.not.have.nested.property('sender.password');",
                  "  pm.collectionVariables.set('messageId', json.data._id);",
                  "  console.log('messageId saved:', json.data._id);",
                  "});",
                  "pm.test('Sender populated', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.data.sender).to.have.property('fullName');",
                  "});"
                ]
              }
